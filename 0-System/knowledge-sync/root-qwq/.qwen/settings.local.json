{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Glob",
      "Grep",
      "Read",
      "Edit",
      "Write",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(ps:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(ssh:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(curl *exe)",
      "Bash(wget *exe)",
      "Bash(mkfs:*)",
      "Bash(dd:*)"
    ],
    "ask": []
  },
  "autoApprove": {
    "fileEdits": true,
    "toolUse": true,
    "bashCommands": true
  }
}
